{
  "version": 2,
  "framework": null,
  "buildCommand": "",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py?route=$1" }
  ],
  "headers": [
    {
      "source": "/data/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Cache-Control", "value": "public, max-age=86400, s-maxage=86400" }
      ]
    },
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
